{
  "entities": {
    "NewsPost": {
      "title": "NewsPost",
      "description": "A news article submitted by a user or published by an admin.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "shortDescription": { "type": "string" },
        "fullDescription": { "type": "string" },
        "location": { "type": "string" },
        "category": { "type": "string" },
        "imageUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "authorId": { "type": "string" },
        "authorEmail": { "type": "string" },
        "authorName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "publishedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "shortDescription", "fullDescription", "status", "authorId", "createdAt", "category"]
    },
    "User": {
      "title": "User",
      "description": "User profile information and roles.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "status": { "type": "string", "enum": ["active", "blocked", "suspended"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "status"]
    },
    "ContactSubmission": {
      "title": "ContactSubmission",
      "description": "A message submitted via the contact form.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "subject", "message", "createdAt"]
    },
    "FifaMatch": {
      "title": "FifaMatch",
      "description": "A FIFA World Cup 2026 match schedule item.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "venue": { "type": "string" },
        "bdTime": { "type": "string" },
        "status": { "type": "string", "enum": ["LIVE", "UPCOMING", "COMPLETED"] },
        "score": { "type": "string" },
        "minute": { "type": "string" },
        "streamUrl": { "type": "string" },
        "group": { "type": "string" },
        "teams": {
          "type": "object",
          "properties": {
            "home": { "type": "string" },
            "away": { "type": "string" },
            "homeFlag": { "type": "string" },
            "awayFlag": { "type": "string" }
          },
          "required": ["home", "away", "homeFlag", "awayFlag"]
        }
      },
      "required": ["id", "date", "venue", "bdTime", "status", "group", "teams"]
    },
    "Advertisement": {
      "title": "Advertisement",
      "description": "An advertisement banner or text.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["image", "text"] },
        "position": { "type": "string", "enum": ["hero", "footer", "sidebar-left", "sidebar-right"] },
        "targetPages": { "type": "array", "items": { "type": "string" }, "description": "List of page paths or 'all' or category slugs" },
        "imageUrl": { "type": "string" },
        "linkUrl": { "type": "string" },
        "textContent": { "type": "string" },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "type", "position", "targetPages", "isActive", "createdAt"]
    }
  },
  "firestore": {
    "/news": { "schema": "NewsPost", "description": "Collection of all news posts." },
    "/users": { "schema": "User", "description": "Collection of user profiles." },
    "/contacts": { "schema": "ContactSubmission", "description": "Collection of contact form submissions." },
    "/ads": { "schema": "Advertisement", "description": "Collection of advertisements." },
    "/fifa-matches": { "schema": "FifaMatch", "description": "Collection of all FIFA World Cup 2026 match schedules." }
  }
}
